<mxfile host="app.diagrams.net" modified="2026-05-01T12:00:00.000Z" agent="ResolveIT-AI" version="24.0.0">
  <diagram id="auth07" name="Authentication Flow">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Authentication Flow — Firebase OAuth → JWT → Backend verify" style="text;html=1;align=center;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="800" height="30" as="geometry" />
        </mxCell>

        <!-- Actors -->
        <mxCell id="user" value="User" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="40" height="60" as="geometry" />
        </mxCell>

        <mxCell id="loginpg" value="Login.jsx&#xa;(React)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="200" y="100" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="fbsdk" value="Firebase JS SDK&#xa;(GoogleAuthProvider /&#xa;signInWithEmail)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="420" y="100" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="fb_auth" value="Firebase Auth&#xa;(cloud)" style="shape=mxgraph.basic.cloud;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="google" value="Google OAuth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="900" y="115" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="user" target="loginpg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s1lbl" value="1. clicks Sign-in" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="125" y="80" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="s2" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="loginpg" target="fbsdk"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s2lbl" value="2. signInWithPopup()" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="365" y="80" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="s3" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="fbsdk" target="fb_auth"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s3lbl" value="3. delegate" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="630" y="80" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="s4" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="fb_auth" target="google"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="s5" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=9" edge="1" parent="1" source="google" target="fb_auth">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="970" y="200"/><mxPoint x="780" y="200"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="s5lbl" value="4. profile + consent" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="850" y="200" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="idtoken_box" value="Firebase ID Token (JWT)&#xa;{ uid, email, name, picture, exp ≈ 1h }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;dashed=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s6" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=9" edge="1" parent="1" source="fb_auth" target="idtoken_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s6lbl" value="5. issues ID Token" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="700" y="225" width="160" height="20" as="geometry" />
        </mxCell>

        <mxCell id="auth_ctx" value="AuthContext.jsx&#xa;{user, token, isAdmin, loading}&#xa;auto-refresh every 50 min" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="200" y="350" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s7" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="idtoken_box" target="auth_ctx"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s7lbl" value="6. store token" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="370" y="320" width="100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="fetch" value="Axios / fetch request&#xa;Authorization: Bearer &lt;ID Token&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="500" y="370" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s8" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="auth_ctx" target="fetch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s8lbl" value="7. attach to API call" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="430" y="430" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="fastapi" value="FastAPI route handler&#xa;Depends(get_current_user)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="820" y="370" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s9" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="fetch" target="fastapi"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="fb_admin" value="firebase_auth.py&#xa;firebase_admin.auth.&#xa;verify_id_token(token)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="820" y="470" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s10" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="fastapi" target="fb_admin"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s10lbl" value="8. verify JWT" style="text;html=1;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="1075" y="430" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="admin_chk" value="Email ∈ ADMIN_EMAILS?&#xa;→ is_admin = True / False" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="540" y="480" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s11" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="fb_admin" target="admin_chk"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="user_dict" value="user dict&#xa;{uid, email, name, picture, is_admin}&#xa;injected into route handler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="200" y="490" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s12" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="admin_chk" target="user_dict"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="invalid" value="HTTP 401&#xa;Invalid / expired token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;dashed=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="820" y="600" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s13" value="on failure" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="fb_admin" target="invalid"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="proceed" value="Pipeline proceeds&#xa;(query / upload / admin / etc.)&#xa;respects is_admin guard for /admin/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="200" y="600" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s14" style="endArrow=classic;html=1;rounded=0;fontSize=9" edge="1" parent="1" source="user_dict" target="proceed"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="note" value="Note: Token is auto-refreshed by AuthContext every 50 minutes (Firebase ID Token TTL ≈ 1 hour),&#xa;so the user stays signed in across long sessions without manual re-auth." style="text;html=1;align=center;fontSize=9;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="200" y="700" width="780" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
