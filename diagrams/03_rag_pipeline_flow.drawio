        <mxCell id="log" value="Log to query_logs&#xa;(mode, thread_id, regenerate_of)&#xa;backward-compat fallback" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="340" y="600" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cache_set" value="Update TTLCache&#xa;{answer, sources,&#xa;confidence, follow_ups}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="620" y="600" width="240" height="70" as="geometry" />
