<mxfile host="app.diagrams.net" modified="2026-05-01T12:00:00.000Z" agent="ResolveIT-AI" version="24.0.0">
  <diagram id="rag03" name="RAG Pipeline Flow">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="RAG Pipeline Flow — Query → Cited Answer" style="text;html=1;align=center;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="700" height="30" as="geometry" />
        </mxCell>

        <mxCell id="user_q" value="User Query&#xa;(Dashboard.jsx)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api" value="POST /query/stream&#xa;{query, scope, mode, thread_id, regenerate_of}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="get_mode" value="get_mode(name)&#xa;→ ModeConfig&#xa;(use_hyde, top_k, top_n, temp, prompt)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="580" y="90" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cache_chk" value="Cache lookup&#xa;sha256(mode:scope:user:query)&#xa;[skipped on regenerate_of]" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="880" y="90" width="160" height="100" as="geometry" />
        </mxCell>

        <mxCell id="cache_hit" value="Return cached&#xa;{answer, sources,&#xa;confidence, follow_ups}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="880" y="220" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="hyde" value="HyDE Expansion&#xa;(if cfg.use_hyde)&#xa;Gemini → 3-5 sentence&#xa;hypothetical passage" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="240" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="embed" value="Embed query&#xa;BAAI/bge-small-en-v1.5&#xa;(384-dim, L2-normalized,&#xa;query prefix)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="300" y="240" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="hybrid" value="Hybrid Search (top-k)&#xa;FAISS IndexFlatIP  +  BM25Okapi&#xa;Reciprocal Rank Fusion (k=60)&#xa;de-dup by chunk_id" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="540" y="240" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="scope" value="Scope filter&#xa;admin / mine / both" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="840" y="240" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="rerank" value="Cross-Encoder Re-rank&#xa;BAAI/bge-reranker-base&#xa;sigmoid → confidence ∈ [0,1]&#xa;keep top_n" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="540" y="360" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="gate" value="Gate check&#xa;top_score &lt; 0.25?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="280" y="360" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="escalate" value="Emit escalation&#xa;sentinel&#xa;(clear sources/conf)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;dashed=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="llm" value="Gemini 2.5 Flash&#xa;system_prompt = ModeConfig.system_prompt&#xa;temperature = ModeConfig.temperature&#xa;stream tokens via SSE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="540" y="470" width="320" height="80" as="geometry" />
        </mxCell>

        <mxCell id="follow" value="Follow-up generator&#xa;Gemini → 3 short questions&#xa;(best-effort, swallow errors)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="240" height="60" as="geometry" />
